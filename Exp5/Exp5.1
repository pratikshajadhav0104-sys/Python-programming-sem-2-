#creating an empty dictionary 
student ={}

#adding key-value pairs 
student["name"]="Rahul"
student["age"]=20
student["course"]="python"

print("dictionary after adding elements:")
print(student)

#updating a vaule 
student["age"]=21

print("\ndictionary after updating a vaule:")
print(student)

#deleting a key-value pair
del student["course"]

print("\n dictionary after deleting a key-value pair.")
print(student)
